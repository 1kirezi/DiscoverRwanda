# App
APP_NAME="Discover Rwanda"
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=discover_rwanda
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/discover_rwanda

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=100

# Redis (for WebSocket sessions & background tasks)
REDIS_URL=redis://localhost:6379/0

# Email (optional for dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
EMAILS_FROM=noreply@discoverrwanda.com
